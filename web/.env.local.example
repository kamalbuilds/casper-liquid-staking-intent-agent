# CSPR.click app ID, register the app at https://cspr.click
NEXT_PUBLIC_CSPR_CLICK_APP_ID=your-cspr-click-app-id

# Base URL of the Liquid Staking Intent Agent backend (agent/src/server.ts)
NEXT_PUBLIC_AGENT_URL=http://localhost:3002

# Deployed IntentPolicy contract hash, used client-side to build the
# execute_intent transaction. Format: 64 hex chars, "hash-" prefix optional.
NEXT_PUBLIC_CONTRACT_HASH=

# Server-side only: same contract hash, used by app/api/events/route.ts to
# read IntentExecuted events from CSPR.cloud without exposing the access key.
CONTRACT_HASH=

# Server-side only: CSPR.cloud access token (docs.cspr.cloud). Never expose
# this with a NEXT_PUBLIC_ prefix.
CSPR_CLOUD_ACCESS_KEY=
