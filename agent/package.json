{
  "name": "liquid-staking-intent-agent",
  "version": "0.1.0",
  "description": "AI agent for liquid staking with constrained policy execution",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "cli": "tsx src/cli.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
